{
  "name": "@vaultguard/extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:chrome": "tsc -b && vite build --mode chrome",
    "build:edge": "tsc -b && vite build --mode edge",
    "build:safari": "tsc -b && vite build --mode safari",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vaultguard/auth": "*",
    "@vaultguard/browser-api": "*",
    "@vaultguard/crypto": "*",
    "@vaultguard/db-local": "*",
    "@vaultguard/models": "*",
    "@vaultguard/permissions": "*",
    "@vaultguard/storage": "*",
    "@vaultguard/utils": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@vaultguard/sync-supabase": "*",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vitest": "^1.6.1"
  }
}