{
  "name": "vaultguard-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:extension": "npm run dev --workspace=apps/extension",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=apps/web",
    "build:extension": "npm run build:chrome --workspace=apps/extension"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
