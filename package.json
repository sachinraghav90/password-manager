{
    "name":  "vaultguard-workspace",
    "private":  true,
    "workspaces":  [
                       "apps/*",
                       "packages/*"
                   ],
    "scripts":  {
                    "dev":  "npm run dev --workspace=apps/web",
                    "dev:extension":  "npm run dev --workspace=apps/extension",
                    "build":  "npm run build --workspaces --if-present",
                    "build:web":  "npm run build --workspace=apps/web",
                    "build:extension":  "npm run build:chrome --workspace=apps/extension",
                    "test:chrome":  "npm run test:chrome --workspace=apps/extension",
                    "build:edge":  "npm run build:edge --workspace=apps/extension",
                    "typecheck:chrome":  "npm run typecheck:chrome --workspace=apps/extension",
                    "typecheck:edge":  "npm run typecheck:edge --workspace=apps/extension",
                    "test:safari":  "npm run test:safari --workspace=apps/extension",
                    "typecheck:safari":  "npm run typecheck:safari --workspace=apps/extension",
                    "test:edge":  "npm run test:edge --workspace=apps/extension",
                    "build:safari":  "npm run build:safari --workspace=apps/extension"
                },
    "devDependencies":  {
                            "autoprefixer":  "^10.5.2",
                            "postcss":  "^8.4.39",
                            "tailwindcss":  "^3.4.17"
                        },
    "dependencies":  {
                         "xlsx":  "^0.18.5"
                     }
}
